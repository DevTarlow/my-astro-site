---
import { getCollection } from 'astro:content'

const posts = await getCollection('blog')

const sorted = [...posts].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)

const recent = sorted.slice(0, 5)

const postsData = posts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate.toISOString(),
  tags: p.data.tags ?? [],
}))

const tagCounts = new Map<string, number>()
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8)
---

<div class="flex flex-col gap-4">
  <aside class="border border-terracotta/30 rounded-lg p-4 bg-paper/90 backdrop-blur supports-[backdrop-filter]:bg-paper/80">
    <h2 class="font-serif text-xs font-semibold text-terracotta uppercase tracking-widest mb-3">
      Search
    </h2>
    <form id="search-form" class="flex gap-2">
      <input
        type="search"
        id="search-input"
        placeholder="Search posts..."
        class="w-full border border-terracotta/20 rounded px-3 py-2 text-sm bg-paper text-ink placeholder-ink/30 focus:outline-none focus:border-terracotta transition-colors"
      />
      <button
        type="submit"
        class="shrink-0 bg-terracotta text-paper text-sm rounded px-4 py-2 hover:opacity-90 transition-opacity font-medium"
      >
        Search
      </button>
    </form>
  </aside>

  <aside class="border border-terracotta/30 rounded-lg p-4 bg-paper/90 backdrop-blur supports-[backdrop-filter]:bg-paper/80">
    <h2 class="font-serif text-xs font-semibold text-terracotta uppercase tracking-widest mb-3">
      Recent Posts
    </h2>
    <ul class="space-y-3">
      {
        recent.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="group block no-underline">
              <span class="block text-sm font-medium text-ink group-hover:text-terracotta transition-colors leading-snug">
                {post.data.title}
              </span>
              <time class="block text-[10px] text-ink/40 mt-0.5">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span class="block text-xs text-ink/50 mt-1 leading-normal line-clamp-2">
                {post.data.description}
              </span>
              <span class="mt-1 inline-block text-[11px] text-terracotta opacity-0 group-hover:opacity-100 transition-opacity">
                Read More →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </aside>

  {
    sortedTags.length > 0 && (
      <aside class="border border-terracotta/30 rounded-lg p-4 bg-paper/90 backdrop-blur supports-[backdrop-filter]:bg-paper/80">
        <h2 class="font-serif text-xs font-semibold text-terracotta uppercase tracking-widest mb-3">
          Browse by Tag
        </h2>
        <div class="flex flex-wrap gap-2">
          {
            sortedTags.map(([tag, count]) => (
              <a
                href={`/blog/tags/${encodeURIComponent(tag)}/`}
                class="inline-flex items-center gap-1 text-xs text-terracotta/70 bg-terracotta/5 px-2 py-1 rounded no-underline hover:bg-terracotta/10 transition-colors"
              >
                #{tag}
                <span class="text-[10px] text-ink/40">{count}</span>
              </a>
            ))
          }
        </div>
        <a
          href="/blog/tags/"
          class="mt-3 inline-block text-[11px] text-terracotta no-underline hover:opacity-80 transition-opacity"
        >
          View all →
        </a>
      </aside>
    )
  }
</div>

<script define:vars={{ postsData }} is:inline>
  const searchForm = document.getElementById('search-form')
  const searchInput = document.getElementById('search-input')
  const defaultContent = document.getElementById('default-content')
  const searchResults = document.getElementById('search-results')

  if (!searchForm || !searchInput || !defaultContent || !searchResults) return

  searchForm.addEventListener('submit', function (e) {
    e.preventDefault()
    const query = searchInput.value.trim().toLowerCase()
    if (!query) {
      clearSearch()
      return
    }

    const words = query.split(/\s+/)
    const matches = postsData.filter(function (post) {
    return words.every(function (word) {
      return post.title.toLowerCase().includes(word) ||
        post.description.toLowerCase().includes(word)
    })
  })

    if (matches.length === 0) {
      searchResults.innerHTML =
        '<div class="space-y-4">' +
        '<div class="flex items-center justify-between">' +
        '<p class="text-sm text-ink/60">No results for "<strong>' + escapeHtml(query) + '</strong>"</p>' +
        '<button data-clear class="text-terracotta hover:opacity-80 transition-opacity" aria-label="Clear search">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
        '</button>' +
        '</div>' +
        '</div>'
    } else {
      let html = ''
      html += '<div class="flex items-center justify-between mb-6">'
      html += '<p class="text-sm text-ink/60">' + matches.length + ' result' + (matches.length !== 1 ? 's' : '') + ' for "<strong>' + escapeHtml(query) + '</strong>"</p>'
      html += '<button data-clear class="text-terracotta hover:opacity-80 transition-opacity" aria-label="Clear search">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
        '</button>'
      html += '</div>'

      html += '<ul class="space-y-12">'
      matches.forEach(function (post) {
        html += '<li>' +
          '<article>' +
          '<time class="block text-sm text-ink/40 mb-1.5">' + new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) + '</time>' +
          '<a href="/blog/' + post.id + '/" class="font-serif text-xl text-ink no-underline hover:text-terracotta transition-colors">' + escapeHtml(post.title) + '</a>' +
          '<p class="mt-2 text-sm text-ink/60 leading-relaxed">' + escapeHtml(post.description) + '</p>' +
          '<a href="/blog/' + post.id + '/" class="mt-2 inline-block text-sm text-terracotta no-underline hover:opacity-80 transition-opacity">Read More →</a>' +
          '</article>' +
          '</li>'
      })
      html += '</ul>'

      searchResults.innerHTML = html
    }

    defaultContent.classList.add('hidden')
    searchResults.classList.remove('hidden')

    searchResults.addEventListener('click', function (e) {
      if (e.target.closest('[data-clear]')) clearSearch()
    })
  })

  function clearSearch () {
    searchInput.value = ''
    searchResults.classList.add('hidden')
    defaultContent.classList.remove('hidden')
    searchResults.innerHTML = ''
  }

  function escapeHtml (str) {
    if (!str) return ''
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  }
</script>
