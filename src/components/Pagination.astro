---
export interface Props {
  currentPage: number
  totalPages: number
  basePath?: string
}

const { currentPage, totalPages, basePath = '/blog' } = Astro.props

function pageUrl(page: number): string {
  if (page === 1) return basePath + '/'
  return `${basePath}/page/${page}/`
}

function getPageNumbers(): (number | 'ellipsis')[] {
  if (totalPages <= 7) {
    return Array.from({ length: totalPages }, (_, i) => i + 1)
  }

  const pages: (number | 'ellipsis')[] = [1]

  if (currentPage > 3) {
    pages.push('ellipsis')
  }

  const start = Math.max(2, currentPage - 1)
  const end = Math.min(totalPages - 1, currentPage + 1)

  for (let i = start; i <= end; i++) {
    pages.push(i)
  }

  if (currentPage < totalPages - 2) {
    pages.push('ellipsis')
  }

  pages.push(totalPages)

  return pages
}

const pageNumbers = getPageNumbers()
const linkClass = 'font-serif text-lg tracking-tight no-underline transition-colors duration-300 border-b-2'
---

<nav class="flex items-center justify-center gap-3 mt-16">
  {
    currentPage > 1
      ? (
        <a
          href={pageUrl(currentPage - 1)}
          class={`${linkClass} text-terracotta border-transparent hover:opacity-80`}
        >
          ← Prev
        </a>
      )
      : (
        <span class={`${linkClass} text-ink/20 border-transparent pointer-events-none`}>
          ← Prev
        </span>
      )
  }

  {
    pageNumbers.map((p) =>
      p === 'ellipsis' ? (
        <span class="font-serif text-lg tracking-tight text-ink/30">…</span>
      ) : (
        <a
          href={pageUrl(p)}
          class={`${linkClass} ${p === currentPage ? 'text-terracotta border-terracotta' : 'text-ink/50 border-transparent hover:text-terracotta hover:border-terracotta'}`}
        >
          {p}
        </a>
      )
    )
  }

  {
    currentPage < totalPages
      ? (
        <a
          href={pageUrl(currentPage + 1)}
          class={`${linkClass} text-terracotta border-transparent hover:opacity-80`}
        >
          Next →
        </a>
      )
      : (
        <span class={`${linkClass} text-ink/20 border-transparent pointer-events-none`}>
          Next →
        </span>
      )
  }
</nav>
