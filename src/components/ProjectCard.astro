---
import type { CollectionEntry } from 'astro:content'
import { excerpt } from '../lib/excerpt'
import ContentImage from './ContentImage.astro'

export interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
---

<article class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(25%-1.125rem)] flex flex-col rounded-lg border border-terracotta/10 bg-white/50 p-4 hover:shadow-sm transition-shadow">
  {
    project.data.image && (
      <a href={`/projects/${project.id}/`}>
        <ContentImage
          src={project.data.image}
          alt=""
          class="w-full aspect-[16/9] object-cover rounded-md mb-4"
        />
      </a>
    )
  }

  <div class="flex-1">
    <time class="block text-xs text-ink/40 mb-1">
      {project.data.pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
      })}
    </time>

    <a
      href={`/projects/${project.id}/`}
      class="font-serif text-lg text-ink no-underline hover:text-terracotta transition-colors"
    >
      {project.data.title}
    </a>

    <p class="mt-2 text-sm text-ink/60 leading-relaxed line-clamp-3">
      {excerpt(project.body ?? '', 200)}
    </p>
  </div>

  <div class="mt-4 flex items-center gap-2 flex-wrap">
    {
      (project.data.tags ?? []).slice(0, 3).map((tag) => (
        <span class="text-xs text-terracotta/70 bg-terracotta/5 px-2 py-0.5 rounded">
          #{tag}
        </span>
      ))
    }
  </div>

  <div class="mt-3 flex items-center gap-3">
    {project.data.github && (
      <a
        href={project.data.github}
        class="inline-flex items-center gap-1 text-xs text-ink/50 hover:text-terracotta transition-colors no-underline"
        target="_blank"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        GitHub
      </a>
    )}
    <a
      href={`/projects/${project.id}/`}
      class="ml-auto text-xs text-terracotta no-underline hover:opacity-80 transition-opacity"
    >
      Details →
    </a>
  </div>
</article>
