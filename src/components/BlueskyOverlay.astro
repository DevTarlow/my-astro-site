<div
  id="bluesky-overlay"
  class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-ink/60 opacity-0 pointer-events-none transition-opacity duration-300"
>
  <div class="relative mt-20 mb-20 w-full max-w-[600px] rounded-lg bg-paper p-6 shadow-xl">
    <div class="flex items-center justify-between border-b border-terracotta/10 pb-4">
      <h2 class="font-serif text-xl font-semibold tracking-tight text-ink">
        Latest from Bluesky
      </h2>
      <button
        id="bluesky-close"
        class="flex h-8 w-8 items-center justify-center rounded-md text-ink/50 transition-colors hover:bg-terracotta/10 hover:text-terracotta"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="bluesky-content" class="mt-6 space-y-4">
      <p class="text-center text-ink/50 py-12">Click the butterfly to load posts</p>
    </div>
  </div>
</div>

<script>
  // eslint-disable-next-line @typescript-eslint/ban-ts-comment
  // @ts-nocheck
  const overlay = document.getElementById('bluesky-overlay')
  const content = document.getElementById('bluesky-content')
  const closeBtn = document.getElementById('bluesky-close')
  const trigger = document.querySelector('[data-bluesky-trigger]')

  let loaded = false

  function escapeHtml (str) {
    if (!str) return ''
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  }

  function byteOffsetToCharIndex (text, byteOffset) {
    let byteCount = 0
    for (let i = 0; i < text.length; i++) {
      if (byteCount >= byteOffset) return i
      const code = text.charCodeAt(i)
      if (code < 0x80) {
        byteCount += 1
      } else if (code < 0x800) {
        byteCount += 2
      } else if (code >= 0xD800 && code <= 0xDBFF) {
        byteCount += 4
        i++
      } else {
        byteCount += 3
      }
    }
    return text.length
  }

  function facetsToHtml (text, facets) {
    if (!facets || facets.length === 0) return escapeHtml(text)

    facets.sort(function (a, b) { return a.index.byteStart - b.index.byteStart })

    let result = ''
    let lastEnd = 0

    for (let i = 0; i < facets.length; i++) {
      const f = facets[i]
      const start = byteOffsetToCharIndex(text, f.index.byteStart)
      const end = byteOffsetToCharIndex(text, f.index.byteEnd)

      if (start > lastEnd) {
        result += escapeHtml(text.slice(lastEnd, start))
      }

      const facetText = text.slice(start, end)
      const escaped = escapeHtml(facetText)

      const feature = f.features[0]
      if (feature && feature.$type === 'app.bsky.richtext.facet#link') {
        result += '<a href="' + escapeHtml(feature.uri) + '" target="_blank" rel="noopener noreferrer" class="text-terracotta hover:underline break-all">' + escaped + '</a>'
      } else if (feature && feature.$type === 'app.bsky.richtext.facet#mention') {
        result += '<a href="https://bsky.app/profile/' + feature.did + '" target="_blank" rel="noopener noreferrer" class="text-terracotta hover:underline">' + escaped + '</a>'
      } else {
        result += escaped
      }

      lastEnd = end
    }

    if (lastEnd < text.length) {
      result += escapeHtml(text.slice(lastEnd))
    }

    return result
  }

  function relativeTime (dateStr) {
    if (!dateStr) return ''
    const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
    if (diff < 60) return 'just now'
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago'
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago'
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago'
    const d = new Date(dateStr)
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  }

  function postUrlFromUri (uri) {
    const parts = uri.split('/')
    return 'https://bsky.app/profile/' + parts[2] + '/post/' + parts[parts.length - 1]
  }

  function renderPost (item) {
    const post = item.post
    const record = post.record
    const author = post.author

    let html = '<div class="py-4 border-b border-terracotta/10 last:border-b-0">'

    html += '<div class="flex items-center gap-2">'
    if (author.avatar) {
      html += '<img src="' + author.avatar + '" alt="" class="h-6 w-6 rounded-full" loading="lazy" />'
    } else {
      html += '<div class="h-6 w-6 rounded-full bg-terracotta/20"></div>'
    }
    html += '<span class="text-sm text-ink/70">@' + escapeHtml(author.handle) + '</span>'
    html += '<span class="text-sm text-ink/30">·</span>'
    html += '<span class="text-sm text-ink/50">' + relativeTime(record.createdAt) + '</span>'
    html += '</div>'

    if (record.text) {
      let renderedText
      if (record.facets && record.facets.length > 0) {
        renderedText = facetsToHtml(record.text, record.facets)
      } else {
        renderedText = escapeHtml(record.text)
      }
      html += '<div class="mt-2 text-[1.0625rem] leading-relaxed text-ink/80">' + renderedText.replace(/\n/g, '<br>') + '</div>'
    }

    if (post.embed) {
      const embed = post.embed

      if (embed.$type === 'app.bsky.embed.images#view') {
        html += '<div class="mt-3 grid gap-2" style="grid-template-columns: repeat(' + (embed.images.length > 1 ? '2' : '1') + ', 1fr)">'
        embed.images.forEach(function (img) {
          html += '<img src="' + img.fullsize + '" alt="' + escapeHtml(img.alt || '') + '" class="w-full rounded-lg object-cover" style="max-height: 300px;" loading="lazy" />'
        })
        html += '</div>'
      }

      if (embed.$type === 'app.bsky.embed.external#view') {
        const ext = embed.external
        html += '<a href="' + escapeHtml(ext.uri) + '" target="_blank" rel="noopener noreferrer" class="mt-3 block rounded-lg border border-terracotta/10 overflow-hidden no-underline hover:bg-terracotta/5 transition-colors">'
        if (ext.thumb) {
          html += '<img src="' + ext.thumb + '" alt="" class="w-full h-40 object-cover" loading="lazy" />'
        }
        html += '<div class="p-3">'
        if (ext.title) html += '<div class="text-sm font-semibold text-ink truncate">' + escapeHtml(ext.title) + '</div>'
        if (ext.description) html += '<div class="text-xs text-ink/50 mt-1 line-clamp-2">' + escapeHtml(ext.description) + '</div>'
        html += '<div class="text-xs text-ink/30 mt-1 truncate">' + escapeHtml(ext.uri) + '</div>'
        html += '</div>'
        html += '</a>'
      }

      if (embed.$type === 'app.bsky.embed.recordWithMedia#view') {
        const media = embed.media
        if (media && media.$type === 'app.bsky.embed.images#view') {
          html += '<div class="mt-3 grid gap-2" style="grid-template-columns: repeat(' + (media.images.length > 1 ? '2' : '1') + ', 1fr)">'
          media.images.forEach(function (img) {
            html += '<img src="' + img.fullsize + '" alt="' + escapeHtml(img.alt || '') + '" class="w-full rounded-lg object-cover" style="max-height: 300px;" loading="lazy" />'
          })
          html += '</div>'
        }
      }
    }

    const pUrl = postUrlFromUri(post.uri)
    html += '<div class="mt-3">'
    html += '<a href="' + pUrl + '" target="_blank" rel="noopener noreferrer" class="text-sm text-terracotta hover:underline no-underline">View on Bluesky →</a>'
    html += '</div>'

    html += '</div>'

    return html
  }

  function open () {
    overlay.classList.remove('opacity-0', 'pointer-events-none')
    document.body.style.overflow = 'hidden'
    if (!loaded) {
      loadPosts()
      loaded = true
    }
  }

  function closeOverlay () {
    overlay.classList.add('opacity-0', 'pointer-events-none')
    document.body.style.overflow = ''
  }

  trigger?.addEventListener('click', open)
  closeBtn?.addEventListener('click', closeOverlay)
  overlay?.addEventListener('click', function (e) {
    if (e.target === overlay) closeOverlay()
  })
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeOverlay()
  })

  async function loadPosts () {
    content.innerHTML = '<p class="text-center text-ink/50 py-12">Loading...</p>'

    try {
      const handle = 'itstarlow.bsky.social'
      const feedUrl = 'https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=' + handle + '&limit=10'

      const feedRes = await fetch(feedUrl)

      if (!feedRes.ok) throw new Error('Failed to fetch data')

      const feed = await feedRes.json()

      let html = ''

      feed.feed.forEach(function (item) {
        html += renderPost(item)
      })

      content.innerHTML = html
    } catch {
      content.innerHTML = '<p class="text-center text-red-500 py-12">Failed to load Bluesky posts. Try again later.</p>'
    }
  }
</script>
