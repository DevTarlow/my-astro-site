---
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import BlueskyOverlay from '../components/BlueskyOverlay.astro'
import MobilePanel from '../components/MobilePanel.astro'

export interface Props {
  title?: string
  description?: string
  image?: string
  ogType?: 'website' | 'article' | 'profile'
}

const { title, description, image, ogType = 'website' } = Astro.props

const siteUrl = 'https://tarlow.space'
const pageTitle = title ? `${title} — Tarlow.space | AI Engineer and Developer` : 'Tarlow.space | AI Engineer & Developer'
const defaultDesc = 'A corner of the web built with intention — A blog about Tarlows projects, local-first tools, and AI exploration.'
const pageDesc = description || defaultDesc

function absUrl(src: string | undefined): string | undefined {
  if (!src) return undefined
  if (src.startsWith('http://') || src.startsWith('https://')) return src
  return siteUrl + src
}
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H879GPJ4GM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args){dataLayer.push(args);}
      gtag('js', new Date());

      gtag('config', 'G-H879GPJ4GM');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" title="Tarlow.space" href="/rss.xml" />

    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={new URL(Astro.url.pathname, siteUrl)} />
    {image && <meta property="og:image" content={absUrl(image)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    {image && <meta name="twitter:image" content={absUrl(image)} />}
  </head>
  <body class="bg-paper">
    <div class="bg-paper text-ink font-sans leading-relaxed antialiased min-h-screen">
      <Navbar />
      <BlueskyOverlay />
      <MobilePanel />
      <slot />
    </div>
  </body>
</html>
