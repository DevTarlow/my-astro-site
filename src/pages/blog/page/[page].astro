---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Sidebar from '../../../components/Sidebar.astro'
import Pagination from '../../../components/Pagination.astro'
import { getPublicBlog } from '../../../lib/posts'
import { excerpt } from '../../../lib/excerpt'
import ContentImage from '../../../components/ContentImage.astro'

export async function getStaticPaths() {
  const posts = await getPublicBlog()
  const totalPages = Math.ceil(posts.length / 5)
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }))
}

const posts = await getPublicBlog()
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const latestImage = posts[0]?.data.featuredimage

const pageSize = 5
const totalPages = Math.ceil(posts.length / pageSize)
const currentPage = Number(Astro.params.page)
const offset = (currentPage - 1) * pageSize
const pagePosts = posts.slice(offset, offset + pageSize)
---

<BaseLayout title={`Blog — Page ${currentPage}`} description="Latest posts from Tarlow on projects, local-first tools, and AI exploration." image={latestImage}>
  <div class="flex flex-col xl:flex-row justify-center xl:gap-8">
    <main class="w-full max-w-[65ch] px-6 py-20">
      <div id="default-content">
        <ul class="space-y-12">
          {
            pagePosts.map((post) => (
            <li>
              <article>
                {
                  post.data.featuredimage && (
                    <a href={`/blog/${post.id}/`}>
                      <ContentImage
                        src={post.data.featuredimage}
                        alt=""
                        class="w-full h-36 object-cover rounded-lg mb-3"
                      />
                    </a>
                  )
                }
                <time class="block text-sm text-ink/40 mb-1.5">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <a
                    href={`/blog/${post.id}/`}
                    class="font-serif text-xl text-ink no-underline hover:text-terracotta transition-colors"
                  >
                    {post.data.title}
                  </a>
                  <p class="mt-2 text-sm text-ink/60 leading-relaxed">
                    {excerpt(post.body ?? '', 250)}
                  </p>
                  <a
                    href={`/blog/${post.id}/`}
                    class="mt-2 inline-block text-sm text-terracotta no-underline hover:opacity-80 transition-opacity"
                  >
                    Read More →
                  </a>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
      <div id="search-results" class="hidden"></div>

      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </main>

    <aside class="hidden xl:block w-64 shrink-0 pt-20 pb-20">
      <Sidebar />
    </aside>
  </div>
</BaseLayout>
