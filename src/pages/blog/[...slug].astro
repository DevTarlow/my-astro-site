---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'
import '../../styles/prose.css'
import ContentImage from '../../components/ContentImage.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
if (!post) {
  return new Response(null, { status: 404 })
}

const { Content } = await render(post)
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.featuredimage} ogType="article">
  <article class="mx-auto max-w-[65ch] px-6 py-20">
    <a
      href="/blog"
      class="inline-block text-sm text-terracotta no-underline hover:opacity-80 transition-opacity mb-6"
    >
      ← Back to Blog
    </a>
    {
      post.data.featuredimage && (
        <ContentImage
          src={post.data.featuredimage}
          alt=""
          class="w-full h-48 object-cover rounded-lg mb-8"
        />
      )
    }
    <header class="mb-12">
      <h1 class="font-serif text-3xl font-semibold leading-tight">
        {post.data.title}
      </h1>

      <div class="mt-4 flex items-center gap-4 text-sm text-ink/50">
        <time>
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>

        {post.data.tags && post.data.tags.length > 0 && (
          <ul class="flex gap-2">
            {post.data.tags.map((tag) => (
              <li class="text-xs text-terracotta/70 bg-terracotta/5 px-2 py-0.5 rounded hover:bg-terracotta/10 transition-colors">
                <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="no-underline text-inherit">#{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </header>

    <div class="prose-custom">
      <Content />
    </div>
  </article>
</BaseLayout>


